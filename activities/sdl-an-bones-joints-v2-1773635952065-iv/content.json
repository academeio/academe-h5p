          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which statement about secondary cartilaginous joints (symphyses) is correct?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which statement about secondary cartilaginous joints (symphyses) is correct?</p>",
              "answers": [
                {
                  "text": "<div>They use hyaline cartilage to connect the bones</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Symphyses use a fibrocartilage disc, not hyaline cartilage. Primary cartilaginous joints (synchondroses) are the ones that use hyaline cartilage.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>They are found exclusively in the appendicular skeleton</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Symphyses are found in the axial skeleton — the vertebral column (intervertebral discs) and the pelvis (pubic symphysis) — not in the limbs.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>They all lie in the midline of the body</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>All symphyses lie in the midline. The pubic symphysis and intervertebral discs are the principal examples. This midline location is a reliable identifying feature.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>They are completely immovable in adults</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Symphyses allow limited movement. The pubic symphysis, for instance, permits slight separation during childbirth.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "All symphyses lie in the midline of the body and use a fibrocartilage disc. The pubic symphysis and intervertebral discs are the principal examples."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct! All symphyses are midline joints — the pubic symphysis and intervertebral discs are the classic examples."
                }
              ],

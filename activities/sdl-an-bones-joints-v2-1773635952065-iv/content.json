          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which feature distinguishes intramembranous ossification from endochondral ossif</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which feature distinguishes intramembranous ossification from endochondral ossification?</p>",
              "answers": [
                {
                  "text": "<div>Bone forms directly from mesenchyme without a prior cartilage model</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>In intramembranous ossification, bone develops directly from embryonic connective tissue (mesenchyme) with no cartilage stage. This pathway forms the flat bones of the skull and the clavicle.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A primary ossification centre appears in the diaphysis during fetal life</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>A primary centre in the diaphysis during fetal life is characteristic of endochondral ossification, not intramembranous.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A growth plate separates the primary and secondary ossification centres</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Growth plates exist only in endochondral ossification, separating the shaft's primary centre from the secondary centres at the bone's ends.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Osteoblasts begin laying down mineral at secondary centres after birth</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Secondary centres appearing after birth are a hallmark of endochondral ossification, which builds bone on a cartilage template.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Intramembranous ossification bypasses cartilage altogether. Bone forms directly from embryonic mesenchyme, without a cartilage template. This is how the skull's flat bones and the clavicle develop."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct! Intramembranous ossification skips the cartilage stage entirely — bone forms directly from mesenchyme."
                }
              ],
              "behaviour": {

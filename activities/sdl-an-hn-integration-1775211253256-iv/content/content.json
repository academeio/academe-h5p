          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which cell type in the thyroid gland is responsible for secreting calcitonin?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which cell type in the thyroid gland is responsible for secreting calcitonin?</p>",
              "answers": [
                {
                  "text": "<div>Chief cells</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Chief cells are found in the parathyroid gland, where they secrete parathyroid hormone (PTH), not calcitonin.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Parafollicular cells</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Parafollicular cells (also called C cells) are larger, paler cells located between thyroid follicles. They secrete calcitonin, which lowers blood calcium levels.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Oxyphil cells</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Oxyphil cells are large, pink cells found in the parathyroid gland. Their exact function remains uncertain, but they do not secrete calcitonin.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Acidophils</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Acidophils are found in the anterior pituitary (adenohypophysis), where they secrete growth hormone and prolactin.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "The thyroid has two functional cell types — follicular cells (producing T3 and T4 from colloid) and parafollicular C cells (secreting calcitonin). Parafollicular cells are the calcitonin-producing cells."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Parafollicular (C) cells sit between thyroid follicles and produce calcitonin. They appear larger and paler than the follicular epithelial cells on H&E staining."
                }
              ],
              "behaviour": {

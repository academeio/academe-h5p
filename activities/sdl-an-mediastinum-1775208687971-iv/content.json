          "buttonOnMobile": false,
          "label": "<p>A CT scan reveals a mass located between the sternum and the anterior surface of</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>A CT scan reveals a mass located between the sternum and the anterior surface of the pericardium in the inferior mediastinum. In which compartment is this mass most likely located?</p>",
              "answers": [
                {
                  "text": "<div>Superior mediastinum</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Incorrect. The superior mediastinum lies above the horizontal plane at the T4/T5 intervertebral disc. A mass between the sternum and pericardium below this plane is in the anterior compartment of the inferior mediastinum.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Anterior mediastinum</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct! The anterior mediastinum is the space between the posterior surface of the sternum and the anterior surface of the pericardium. It normally contains the thymus, fatty tissue, internal thoracic vessels, and lymph nodes.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Middle mediastinum</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Incorrect. The middle mediastinum contains the pericardium and the heart itself. The mass described lies anterior to the pericardium, placing it in the anterior mediastinum.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Posterior mediastinum</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Incorrect. The posterior mediastinum occupies the space between the posterior surface of the pericardium and the vertebral column (T5–T12). The mass is in front of the pericardium, not behind it.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "The inferior mediastinum is divided into three compartments based on their relation to the pericardium: anterior (in front of it), middle (containing it and the heart), and posterior (behind it)."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct! The anterior mediastinum lies between the sternum and the pericardium, containing the thymus, fatty tissue, and internal thoracic vessels."
                }
              ],
              "behaviour": {
                "enableRetry": true,
                "enableSolutionsButton": true,
                "enableCheckButton": true,

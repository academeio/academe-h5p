          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>What hormonal event triggers ovulation around day 14 of the menstrual cycle?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>What hormonal event triggers ovulation around day 14 of the menstrual cycle?</p>",
              "answers": [
                {
                  "text": "<div>A sudden drop in progesterone</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Progesterone drops near day 26 when the corpus luteum degenerates, triggering menstruation — not ovulation.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A surge in luteinising hormone (LH)</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Rising oestrogen from the dominant Graafian follicle exerts positive feedback on the pituitary, causing an LH surge that ruptures the follicle and releases the oocyte.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A surge in follicle-stimulating hormone (FSH)</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>FSH drives follicular growth during the follicular phase, but it is the mid-cycle LH surge — not an FSH surge — that triggers ovulation.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A rise in inhibin B</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Inhibin B from granulosa cells selectively suppresses FSH secretion. It does not trigger ovulation.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Ovulation is triggered by an LH surge. Rising oestrogen from the dominant Graafian follicle switches from negative to positive feedback on the pituitary, causing the sharp LH peak that ruptures the follicle."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done! The LH surge, driven by positive feedback from rising oestrogen, ruptures the Graafian follicle and releases the oocyte into the fallopian tube."
                }
              ],
              "behaviour": {
                "enableRetry": true,
                "enableSolutionsButton": true,
                "enableCheckButton": true,

          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which hormone, produced exclusively by the trophoblast, is detected by pregnancy</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which hormone, produced exclusively by the trophoblast, is detected by pregnancy tests?</p>",
              "answers": [
                {
                  "text": "<div>Progesterone</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Progesterone rises in pregnancy but is also elevated during the luteal phase of every normal menstrual cycle, so it cannot reliably distinguish pregnancy from a normal cycle.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Human placental lactogen</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Human placental lactogen is produced by the syncytiotrophoblast later in pregnancy and has metabolic functions, but it is not used for routine pregnancy detection.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Human chorionic gonadotrophin</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. hCG is produced exclusively by the trophoblast after implantation. It appears in blood by day 8–10 and in urine by day 10–14 after conception, making it the ideal specific marker for pregnancy.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Oestradiol</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Oestradiol rises in pregnancy but is present at significant levels throughout the normal menstrual cycle, making it non-specific for pregnancy detection.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Review the pregnancy tests section: hCG is produced exclusively by trophoblast tissue and becomes detectable in urine about 10–14 days after conception."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done! hCG from the trophoblast is the basis of all pregnancy tests — both urine immunoassay strips and quantitative blood tests."
                }
              ],
              "behaviour": {
                "enableRetry": true,
                "enableSolutionsButton": true,

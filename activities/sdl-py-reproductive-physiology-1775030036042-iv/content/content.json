          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which hormone is detected by pregnancy tests to confirm early pregnancy?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which hormone is detected by pregnancy tests to confirm early pregnancy?</p>",
              "answers": [
                {
                  "text": "<div>Progesterone</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Progesterone maintains the endometrium during pregnancy, but it is also present during the normal luteal phase, making it unsuitable as a pregnancy-specific marker.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Human placental lactogen (hPL)</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>hPL is produced by the syncytiotrophoblast later in pregnancy and has metabolic effects, but standard pregnancy tests do not detect it.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Human chorionic gonadotrophin (hCG)</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. hCG is produced exclusively by the trophoblast after implantation. It appears in blood by day 8–10 and in urine by day 10–14 after conception, forming the basis of all pregnancy tests.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Oestradiol</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Oestradiol rises in pregnancy but also fluctuates during normal menstrual cycles, so it is not specific enough for pregnancy detection.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Pregnancy tests detect human chorionic gonadotrophin (hCG), produced exclusively by the trophoblast after implantation. It is detectable in urine from about 10–14 days post-conception."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct! hCG from the trophoblast is the basis of all pregnancy tests. In a healthy early pregnancy, its levels double approximately every 48 hours."
                }
              ],
              "behaviour": {
                "enableRetry": true,
                "enableSolutionsButton": true,
                "enableCheckButton": true,

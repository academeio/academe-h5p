          "buttonOnMobile": false,
          "label": "<p>When inserting a chest drain into an intercostal space, the needle should be pas</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>When inserting a chest drain into an intercostal space, the needle should be passed:</p>",
              "answers": [
                {
                  "text": "<div>Just below the upper rib of the space</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Unsafe — this takes the needle directly through the neurovascular bundle running in the costal groove along the lower border of the upper rib.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Just above the lower rib of the space</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The VAN bundle hugs the underside of the rib above, so hugging the top of the lower rib keeps the needle safely below the vessels and nerve.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>In the exact middle of the intercostal space</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Not reliable — the bundle lies high in the space, so a mid-space approach still risks injury, particularly in narrower spaces.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Through the costal cartilage of the upper rib</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Cartilage is firm and does not provide a safe entry path; the bundle still lies just below it in the costal groove.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Remember: the neurovascular bundle runs in the costal groove on the underside of each rib. Enter just above the lower rib to stay safe."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct. Always hug the upper border of the lower rib to stay clear of the VAN bundle (Vein, Artery, Nerve) in the costal groove."
                }
              ],
              "behaviour": {

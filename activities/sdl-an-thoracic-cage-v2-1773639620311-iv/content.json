          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>At which vertebral level does the oesophagus pierce the diaphragm?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>At which vertebral level does the oesophagus pierce the diaphragm?</p>",
              "answers": [
                {
                  "text": "<div>T8</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>T8 is the level of the vena caval foramen (IVC), not the oesophagus. Remember: I ate (8) — IVC at T8.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>T10</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The oesophageal hiatus lies at T10. Mnemonic: I ate (8) ten (10) eggs at twelve (12) — IVC T8, oesophagus T10, aorta T12.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>T12</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>T12 is the aortic hiatus. The oesophagus pierces higher, at T10.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>T6</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>T6 is the dermatome level of the xiphoid, not a diaphragmatic opening. The oesophagus passes through at T10.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Use the mnemonic 'I ate ten eggs at twelve': IVC at T8, oesophagus at T10, aorta at T12."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Excellent. The mnemonic 'I ate ten eggs at twelve' locks in IVC at T8, oesophagus at T10, and aorta at T12."
                }
              ],
              "behaviour": {
                "enableRetry": true,
                "enableSolutionsButton": true,

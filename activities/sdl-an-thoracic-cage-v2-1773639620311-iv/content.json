          },
          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which of the following thoracic vertebrae is TYPICAL, carrying demifacets on its</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which of the following thoracic vertebrae is TYPICAL, carrying demifacets on its body for rib articulation?</p>",
              "answers": [
                {
                  "text": "<div>T1</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>T1 is atypical — it has a single complete facet for the first rib, not demifacets.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>T5</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>T5 lies within the typical range (T2–T8). Its body carries superior and inferior demifacets that share the head of a typical rib with the neighbouring vertebra.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>T11</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>T11 is atypical — it has a single complete facet and no costotransverse joint.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>T12</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>T12 is atypical — it carries a single complete facet and lacks a costotransverse articulation.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Remember the rule: wherever a rib has a single facet, its vertebra is atypical too. T1, T9–T12 are atypical; T2–T8 are typical."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct. T2–T8 are typical and carry demifacets, because a typical rib head spans two adjacent vertebrae."
                }
              ],
              "behaviour": {

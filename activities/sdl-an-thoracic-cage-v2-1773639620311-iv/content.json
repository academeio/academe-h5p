          "buttonOnMobile": false,
          "label": "<p>The sternal angle (Angle of Louis) corresponds to all of the following EXCEPT:</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>The sternal angle (Angle of Louis) corresponds to all of the following EXCEPT:</p>",
              "answers": [
                {
                  "text": "<div>The level of the second costal cartilage</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct correlate — the sternal angle is the starting point for counting ribs because it meets the 2nd costal cartilage.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>The bifurcation of the trachea into main bronchi</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct correlate — the trachea divides at the level of the sternal angle.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>The disc between vertebrae T2 and T3</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The sternal angle lies at the T4/T5 intervertebral disc posteriorly, not T2/T3. T2 corresponds to the jugular notch.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>The boundary between superior and inferior mediastinum</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct correlate — the transverse thoracic plane through the sternal angle separates the superior from the inferior mediastinum.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Review the sternal angle's correlates. Posteriorly it sits at the T4/T5 disc, not higher up at T2/T3 (which is the jugular notch level)."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done. The sternal angle marks T4/T5 posteriorly — a key landmark for rib counting, tracheal bifurcation, and mediastinal division."
                }
              ],
              "behaviour": {

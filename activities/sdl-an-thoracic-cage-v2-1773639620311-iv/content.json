          "label": "<p>Which structure is contained within the MIDDLE mediastinum?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which structure is contained within the MIDDLE mediastinum?</p>",
              "answers": [
                {
                  "text": "<div>Arch of the aorta</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The arch of the aorta lies in the superior mediastinum, above the transverse thoracic plane.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Heart within the pericardium</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The middle mediastinum contains the heart and the pericardium, with the roots of the great vessels.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Descending thoracic aorta</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The descending thoracic aorta lies in the posterior mediastinum, behind the pericardium.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Thymus gland</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The thymus lies in the superior and anterior mediastinum, in front of the pericardium.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Review the four subdivisions: superior (arch, SVC, trachea, thymus), anterior (fat, nodes), middle (heart & pericardium), posterior (descending aorta, oesophagus, azygos)."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct. The middle mediastinum is essentially the pericardial compartment, containing the heart and pericardium."
                }
              ],

          "buttonOnMobile": false,
          "label": "<p>During quiet inspiration, which movement is primarily responsible for increasing</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>During quiet inspiration, which movement is primarily responsible for increasing the anteroposterior (front-to-back) diameter of the thorax?</p>",
              "answers": [
                {
                  "text": "<div>Bucket-handle movement of the lower ribs</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Bucket-handle movement of ribs 7–10 widens the chest from side to side (transverse diameter), not front to back.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Pump-handle movement of the upper ribs</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Elevation of ribs 2–6 swings the sternum forward and upward, increasing the AP diameter like an old water pump handle.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Descent of the diaphragm</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The diaphragm increases the vertical (craniocaudal) dimension of the thorax, not the AP diameter.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Contraction of the innermost intercostal muscles</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The innermost intercostals assist in expiration mechanics and do not directly increase AP diameter.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Think pump-handle for upper ribs (AP diameter) and bucket-handle for lower ribs (transverse diameter). The diaphragm handles vertical expansion."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct. Pump-handle motion of the upper ribs increases AP diameter; bucket-handle of the lower ribs increases transverse diameter; diaphragm adds the vertical dimension."
                }
              ],
              "behaviour": {

          "label": "<p>Which structure is found in the MIDDLE mediastinum?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which structure is found in the MIDDLE mediastinum?</p>",
              "answers": [
                {
                  "text": "<div>Arch of the aorta</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The arch of the aorta lies in the superior mediastinum, above the sternal angle plane.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Heart and pericardium</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The middle mediastinum contains the heart enclosed within the pericardium, along with the roots of the great vessels.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Descending thoracic aorta</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The descending aorta lies in the posterior mediastinum, behind the pericardium.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Thymus gland</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The thymus sits in the superior mediastinum (and extends into the anterior mediastinum), not the middle.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Middle mediastinum = heart and pericardium. Superior holds the great vessels and trachea; anterior holds fat/nodes; posterior holds the descending aorta and oesophagus."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done. The middle mediastinum is essentially the heart and pericardium — a small but critical compartment."
                }
              ],

          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which statement BEST describes the bucket-handle movement of respiration?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which statement BEST describes the bucket-handle movement of respiration?</p>",
              "answers": [
                {
                  "text": "<div>Upper ribs (2–6) elevate, increasing the anteroposterior diameter of the chest</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>This describes the pump-handle movement of the upper ribs, which increases the AP diameter — not the bucket-handle.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Lower ribs (7–10) elevate, increasing the transverse diameter of the chest</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The bucket-handle movement involves the lower ribs swinging their middle portions outward, widening the thorax from side to side.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>The diaphragm contracts and descends, increasing the vertical diameter</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>This is diaphragmatic action, the third dimension of breathing — not a rib movement at all.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Floating ribs (11–12) flare outward, increasing abdominal volume</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Floating ribs play little role in normal respiration. The bucket-handle action belongs to ribs 7–10.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Pump-handle (upper ribs 2–6) increases the AP diameter; bucket-handle (lower ribs 7–10) increases the transverse diameter. Both occur together during every breath."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Excellent. Pump-handle = upper ribs, AP diameter; bucket-handle = lower ribs, transverse diameter. Both happen with every breath."
                }
              ],
              "behaviour": {

          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which laboratory marker is the earliest indicator of iron depletion, falling before haemoglobin levels decline?</p>",
              "answers": [
                {
                  "text": "<div>Total iron binding capacity</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>TIBC rises (not falls) as the body upregulates transferrin to capture more iron, and this change occurs in stage two, not stage one.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Mean corpuscular volume</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>MCV falls only in stage three when red cells become microcytic. It is a late marker of established iron deficiency anaemia.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Serum ferritin</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Serum ferritin reflects iron stores and falls in stage one of iron depletion, well before haemoglobin or red cell indices are affected.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Transferrin saturation</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Transferrin saturation falls below 20% in stage two, after stores are already depleted. It is useful but not the earliest marker.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Iron depletion progresses in three stages: ferritin falls first (stage 1), then transferrin saturation drops (stage 2), and finally haemoglobin and MCV fall (stage 3)."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done. Serum ferritin is the first laboratory value to change in iron depletion, making it the best screening test for early deficiency."
                }
              ],

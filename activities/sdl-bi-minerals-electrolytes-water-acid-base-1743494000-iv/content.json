                {
                  "library": "H5P.MultiChoice 1.16",
                  "params": {
                    "question": "<p>India's National Iodisation Programme was introduced to combat which condition caused by iodine deficiency?</p>",
                    "answers": [
                      {
                        "text": "<div>Iron deficiency anaemia</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Iron deficiency anaemia is addressed by the Anaemia Mukt Bharat programme, not the iodisation programme.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Osteoporosis</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Osteoporosis relates to calcium and vitamin D metabolism, not iodine.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Hypothyroidism and goitre</div>",
                        "correct": true,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Correct. Iodine is essential for thyroid hormone synthesis. Deficiency leads to hypothyroidism and goitre, which India's iodised salt programme has targeted since 1983.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Acrodermatitis enteropathica</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Acrodermatitis enteropathica is a genetic zinc absorption disorder and is unrelated to iodine.</div>",
                          "notChosenFeedback": ""
                        }
                      }
                    ],
                    "overallFeedback": [
                      {
                        "from": 0,
                        "to": 50,
                        "feedback": "Iodine is needed to synthesise thyroid hormones (T3 and T4). Without it, the thyroid enlarges (goitre) and hormone output falls (hypothyroidism)."
                      },
                      {
                        "from": 51,
                        "to": 100,
                        "feedback": "Well done. India mandated iodised salt in 1983 to prevent hypothyroidism and goitre, though coverage remains uneven in some regions."
                      }
                    ],

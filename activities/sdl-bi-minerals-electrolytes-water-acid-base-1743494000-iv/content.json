              "questions": [
                {
                  "library": "H5P.MultiChoice 1.16",
                  "params": {
                    "question": "<p>Which buffer system is the most important extracellular buffer in blood?</p>",
                    "answers": [
                      {
                        "text": "<div>Phosphate buffer system</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>The phosphate buffer operates mainly inside cells and in urine (pKa 6.8). It is not the principal extracellular buffer.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Bicarbonate buffer system</div>",
                        "correct": true,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Correct. The bicarbonate buffer is the most important extracellular buffer. It is regulated by both the lungs (CO\u2082 excretion) and kidneys (HCO\u2083\u207b reabsorption).</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Haemoglobin buffer system</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Haemoglobin is a powerful buffer but operates inside red blood cells (intracellular), not in the extracellular fluid.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Albumin buffer system</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Albumin contributes to protein buffering but is far less significant than the bicarbonate system in extracellular fluid.</div>",
                          "notChosenFeedback": ""
                        }
                      }
                    ],
                    "overallFeedback": [
                      {
                        "from": 0,
                        "to": 50,
                        "feedback": "The bicarbonate buffer system is the most important extracellular buffer. H\u207a + HCO\u2083\u207b \u21cc H\u2082CO\u2083 \u21cc H\u2082O + CO\u2082. The lungs control CO\u2082 and the kidneys control HCO\u2083\u207b."
                      },
                      {
                        "from": 51,
                        "to": 100,
                        "feedback": "Well done. The bicarbonate buffer system is the principal extracellular buffer, described by the Henderson-Hasselbalch equation: pH = 6.1 + log([HCO\u2083\u207b] / [dissolved CO\u2082])."
                      }
                    ],

                {
                  "library": "H5P.MultiChoice 1.16",
                  "params": {
                    "question": "<p>Which of the following is a characteristic clinical feature of zinc deficiency?</p>",
                    "answers": [
                      {
                        "text": "<div>Kayser-Fleischer rings</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Kayser-Fleischer rings are corneal copper deposits seen in Wilson disease, not zinc deficiency.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Kinky brittle hair</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Kinky brittle hair is the hallmark of Menkes disease, which results from defective copper absorption.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Poor wound healing</div>",
                        "correct": true,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Correct. Zinc is a cofactor for over 300 enzymes. Deficiency impairs wound healing, causes growth retardation, hair loss, and loss of taste and smell.</div>",
                          "notChosenFeedback": ""
                        }
                      },
                      {
                        "text": "<div>Goitre</div>",
                        "correct": false,
                        "tipsAndFeedback": {
                          "tip": "",
                          "chosenFeedback": "<div>Goitre results from iodine deficiency leading to compensatory thyroid enlargement, not zinc deficiency.</div>",
                          "notChosenFeedback": ""
                        }
                      }
                    ],
                    "overallFeedback": [
                      {
                        "from": 0,
                        "to": 50,
                        "feedback": "Zinc is essential for over 300 enzymes. Its deficiency causes poor wound healing, growth retardation, hair loss, and loss of taste and smell \u2014 remember these as the classic features."
                      },
                      {
                        "from": 51,
                        "to": 100,
                        "feedback": "Correct. Zinc deficiency classically presents with poor wound healing, growth retardation, hair loss, and impaired taste and smell."
                      }
                    ],

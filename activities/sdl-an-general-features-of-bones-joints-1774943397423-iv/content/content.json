          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which of the following bones is formed by intramembranous ossification?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which of the following bones is formed by intramembranous ossification?</p>",
              "answers": [
                {
                  "text": "<div>Femur</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The femur is a long bone formed by endochondral ossification, where a cartilage model is gradually replaced by bone tissue.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Vertebra</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Vertebrae are irregular bones formed by endochondral ossification from cartilaginous precursors.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Parietal bone</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The parietal bone, part of the skull vault, forms directly from mesenchyme without a cartilage model — this is intramembranous ossification.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Rib</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Ribs form by endochondral ossification. They develop from a cartilage model that is progressively replaced by bone.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Remember: intramembranous ossification forms bone directly from mesenchyme without a cartilage model. This applies to the skull vault bones, clavicle, and mandible. Most other bones use endochondral ossification."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct! Flat bones of the skull vault (frontal, parietal, temporal, occipital), the clavicle, and the mandible form by intramembranous ossification — directly from mesenchyme."
                }
              ],
              "behaviour": {

          "buttonOnMobile": false,
          "label": "<p>Which of the following muscles forms the posterior wall of the axilla?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which of the following muscles forms the posterior wall of the axilla?</p>",
              "answers": [
                {
                  "text": "<div>Pectoralis major</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Pectoralis major forms the anterior wall of the axilla, not the posterior wall. It is one of the chest muscles on the front of the thorax.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Serratus anterior</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Serratus anterior forms the medial wall of the axilla, running along the side of the chest over the upper ribs.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Subscapularis</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The posterior wall is formed by subscapularis, latissimus dorsi, and teres major — muscles originating from the scapula and lower back.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Deltoid</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The deltoid covers the shoulder joint superiorly but does not form any wall of the axilla.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "The posterior wall is formed by subscapularis, latissimus dorsi, and teres major. A useful way to remember: the anterior wall has the pectorals (chest muscles), and the posterior wall has the scapular muscles."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done. The posterior wall comprises subscapularis, latissimus dorsi, and teres major. Remembering which muscles form each wall helps you predict which structures are at risk during surgical approaches."
                }
              ],
              "behaviour": {

          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which statement best explains the principle of molecular organisation described </p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which statement best explains the principle of molecular organisation described in this video?</p>",
              "answers": [
                {
                  "text": "<div>Molecules inside a cell are randomly distributed and self-organise as needed</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>This is incorrect. The video emphasises that nothing inside a cell is random — every molecule is precisely positioned to perform a specific job.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Every molecule inside a cell is positioned to perform a specific function</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Molecular organisation means that a cell's physical structure directly determines its biological function. Each component is placed with precision.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Molecular organisation applies only to membrane-bound organelles</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>This is too narrow. Molecular organisation applies to all cellular components, including non-membrane-bound structures like ribosomes and the cytoskeleton.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A cell's function is independent of its physical structure</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The opposite is true. The video states that structure directly determines function — this is the core principle of molecular organisation.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Review the concept: molecular organisation means a cell's physical structure directly determines its biological function. Nothing inside a cell is randomly placed."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done! Molecular organisation is the foundational principle that every structure within a cell exists to serve a specific biological function."
                }
              ],
              "behaviour": {

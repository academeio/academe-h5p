          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which of the following cellular structures lacks a surrounding membrane?</p>",
              "answers": [
                {
                  "text": "<div>Lysosome</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Lysosomes are single-membrane-bound organelles that maintain an acidic internal environment for digestion.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Peroxisome</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Peroxisomes are membrane-bound organelles that carry out oxidative reactions, including fatty acid breakdown.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Nucleus</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The nucleus is enclosed by a double membrane called the nuclear envelope.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Ribosome</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Ribosomes uniquely have no membrane. They are found free in the cytosol or attached to the rough endoplasmic reticulum, where they synthesise proteins.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "The correct answer is the ribosome. Unlike lysosomes, peroxisomes, and the nucleus, ribosomes have no membrane and exist free in the cytosol or on the rough ER."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done! Ribosomes are the only major cellular structure mentioned that lacks a surrounding membrane."
                }
              ],

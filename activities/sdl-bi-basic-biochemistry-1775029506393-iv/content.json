          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which organelle generates ATP through oxidative phosphorylation?</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which organelle generates ATP through oxidative phosphorylation?</p>",
              "answers": [
                {
                  "text": "<div>Nucleus</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The nucleus stores DNA and produces messenger RNA. It does not generate ATP.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Ribosome</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Ribosomes are the cell's protein factories. They translate mRNA into proteins but do not produce ATP.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Mitochondrion</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Mitochondria are the cell's powerhouse, generating ATP through oxidative phosphorylation. Metabolically active cells like cardiac myocytes contain roughly 5,000 mitochondria.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Lysosome</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Lysosomes are responsible for digesting worn-out organelles and foreign material, not for ATP production.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "The correct answer is the mitochondrion. It is a double-membraned organelle that generates ATP through oxidative phosphorylation."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct! Mitochondria generate ATP via oxidative phosphorylation — the more metabolically active the cell, the more mitochondria it contains."
                }
              ],
              "behaviour": {

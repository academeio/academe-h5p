          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>How many sodium ions does the Na⁺/K⁺-ATPase pump move out of the cell in each cy</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>How many sodium ions does the Na⁺/K⁺-ATPase pump move out of the cell in each cycle?</p>",
              "answers": [
                {
                  "text": "<div>One</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Incorrect. The pump moves more than one sodium ion per cycle. One ATP molecule drives the transport of multiple ions.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Two</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Two is the number of potassium ions moved into the cell per cycle, not the number of sodium ions moved out.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Three</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. The Na⁺/K⁺-ATPase moves three sodium ions out and two potassium ions in per cycle, using one ATP molecule. This creates the electrical gradient essential for nerve and muscle function.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>Four</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>The total ions moved per cycle is five (3 Na⁺ out + 2 K⁺ in), not four sodium ions.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "The Na⁺/K⁺-ATPase moves three sodium ions out and two potassium ions in per cycle, consuming one ATP. This 3:2 ratio generates the cell's electrical gradient."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct! The pump moves 3 Na⁺ out and 2 K⁺ in per ATP — this unequal exchange creates the electrochemical gradient that nerve and muscle cells depend on."
                }
              ],
              "behaviour": {

          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>Which transporter mediates the absorption of dietary fructose across the intesti</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>Which transporter mediates the absorption of dietary fructose across the intestinal brush border?</p>",
              "answers": [
                {
                  "text": "<div>SGLT-1, using secondary active transport with sodium</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>SGLT-1 co-transports glucose and galactose with sodium, not fructose. This is also why oral rehydration salts work.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>GLUT-2, using facilitated diffusion</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>GLUT-2 transports monosaccharides out of the enterocyte into the blood on the basolateral side, not across the brush border.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>GLUT-4, an insulin-dependent transporter</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>GLUT-4 is insulin-dependent and operates in skeletal muscle and adipose tissue, not in intestinal absorption.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>GLUT-5, using facilitated diffusion</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Fructose enters enterocytes via GLUT-5 by facilitated diffusion, independent of sodium or ATP, and exits basolaterally via GLUT-2.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Review the three absorption routes: SGLT-1 (glucose/galactose, active), GLUT-5 (fructose, passive), and GLUT-2 (basolateral exit)."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Correct. Fructose uses GLUT-5 at the brush border — a passive route that distinguishes it from glucose and galactose."
                }
              ],
              "behaviour": {

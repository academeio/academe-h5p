          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>In which of the following patients would HbA1c give a misleadingly low result an</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>In which of the following patients would HbA1c give a misleadingly low result and therefore be unreliable for monitoring diabetes?</p>",
              "answers": [
                {
                  "text": "<div>A patient who ate a heavy breakfast two hours before the test</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>HbA1c reflects glucose bound over the red cell lifespan and is unaffected by recent meals — no fasting is required.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A patient with haemolytic anaemia</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Haemolysis shortens red cell lifespan, so haemoglobin spends less time exposed to glucose, producing a falsely low HbA1c.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A patient with well-controlled hypertension</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Hypertension itself does not alter red cell lifespan or haemoglobin glycation and has no effect on HbA1c.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>A patient with mild hypothyroidism</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Thyroid status does not meaningfully affect red cell turnover enough to invalidate HbA1c.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "HbA1c depends on glucose binding over the full red cell lifespan (~120 days). Conditions that shorten that lifespan give a falsely low reading."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Right. Anything that shortens red cell lifespan — haemolytic anaemia, sickle cell disease, recent transfusion — makes HbA1c unreliable."
                }
              ],
              "behaviour": {

          },
          "pause": true,
          "displayType": "poster",
          "buttonOnMobile": false,
          "label": "<p>What is the net yield from one molecule of glucose passing through glycolysis al</p>",
          "x": 30,
          "y": 30,
          "width": 40,
          "height": 25,
          "libraryTitle": "Multiple Choice",
          "action": {
            "library": "H5P.MultiChoice 1.16",
            "params": {
              "question": "<p>What is the net yield from one molecule of glucose passing through glycolysis alone?</p>",
              "answers": [
                {
                  "text": "<div>2 ATP, 2 NADH, and 2 pyruvate</div>",
                  "correct": true,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Correct. Phase one invests 2 ATP; phase two generates 4 ATP and 2 NADH, giving a net of 2 ATP and 2 NADH per glucose.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>4 ATP, 2 NADH, and 2 pyruvate</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>4 ATP is the gross yield. You must subtract the 2 ATP spent in the energy investment phase to get the net.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>2 ATP, 2 FADH2, and 2 lactate</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>Glycolysis produces NADH, not FADH2. Lactate forms only under anaerobic conditions to regenerate NAD+.</div>",
                    "notChosenFeedback": ""
                  }
                },
                {
                  "text": "<div>30–32 ATP per glucose</div>",
                  "correct": false,
                  "tipsAndFeedback": {
                    "tip": "",
                    "chosenFeedback": "<div>That figure reflects complete aerobic oxidation through the TCA cycle and oxidative phosphorylation, not glycolysis alone.</div>",
                    "notChosenFeedback": ""
                  }
                }
              ],
              "overallFeedback": [
                {
                  "from": 0,
                  "to": 50,
                  "feedback": "Glycolysis spends 2 ATP and generates 4, leaving a net of 2 ATP, plus 2 NADH and 2 pyruvate."
                },
                {
                  "from": 51,
                  "to": 100,
                  "feedback": "Well done. Remember PFK-1 is the rate-limiting enzyme, and this yield is the sole ATP source for red blood cells."
                }
              ],
              "behaviour": {
